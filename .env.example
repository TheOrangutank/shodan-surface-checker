# Shodan API key — get yours at https://account.shodan.io/
# Used by: src/lib/shodan.ts (server-side scans only)
SHODAN_API_KEY=your_shodan_api_key_here

# Supabase project — create a free project at https://supabase.com/
# Used by: src/lib/db.ts (monitored assets, sessions, passkeys, rate limits)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Public origin for passkeys and CSRF origin checks.
# Must be the full URL with scheme, no trailing slash.
# Used by: src/lib/auth.ts, src/lib/webauthn.ts
APP_ORIGIN=https://your-domain.example.com
# WebAuthn relying party ID — hostname only, must match APP_ORIGIN hostname.
RP_ID=your-domain.example.com

# Local dev (passkeys supported on localhost):
# APP_ORIGIN=http://localhost:3000
# RP_ID=localhost

# Session signing secret — generate with: openssl rand -base64 48
# Used by: src/lib/auth.ts (session + CSRF tokens)
SESSION_SECRET=replace_with_long_random_secret

# One-time gate for first passkey registration — generate with: openssl rand -base64 48
# Used by: src/lib/auth.ts, /setup-passkey page
PASSKEY_SETUP_TOKEN=replace_with_long_random_setup_token

# Leave false after first passkey registration. Set true only to re-enroll on a new device/domain.
ALLOW_PASSKEY_REENROLL=false
